# API Keys for AI Services
# Copy this file to .env.local and fill in your actual API keys

# Gemini API Key (Google AI)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Exa API Key (for web search)
# Get from: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# OpenRouter API Key (powers the Claude model)
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Subconscious API Key (powers GLM 5.2 and Qwen 3.6)
# Get from: https://subconscious.dev
SUBCONSCIOUS_API_KEY=your_subconscious_api_key_here

# Resend email (OTP auth)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=your_verified_sender_email
RESEND_FROM_NAME=StratifyPM

# Neon Postgres (database)
# Get from: https://neon.tech
DATABASE_URL=your_neon_database_url

# Auth secret (generate a long random string)
AUTH_SECRET=your_random_auth_secret
